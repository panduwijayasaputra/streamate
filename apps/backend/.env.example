# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=streamate

# Application Configuration
PORT=3001
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# YouTube API Configuration
# These are required for YouTube integration. If not using, set dummy values.
YOUTUBE_API_KEY=your-youtube-api-key
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3001/auth/youtube/callback
YOUTUBE_CHAT_POLL_INTERVAL=5000
YOUTUBE_MAX_CHAT_HISTORY=1000
YOUTUBE_RATE_LIMIT_PER_MINUTE=100

# OpenAI Configuration
# Required for AI response system. If not using, set dummy value.
OPENAI_API_KEY=your-openai-api-key

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json